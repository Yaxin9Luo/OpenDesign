# Required
GEMINI_API_KEY=AIza...

# Backend selection — pick ONE of:

# Option A: stock Anthropic (uses claude-opus-4-7)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenRouter proxy (uses anthropic/claude-opus-4.7)
# Takes precedence over ANTHROPIC_API_KEY if both are set.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional overrides (rare):
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# PLANNER_MODEL=anthropic/claude-opus-4.7
# CRITIC_MODEL=anthropic/claude-opus-4.7
