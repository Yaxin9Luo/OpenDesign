# ── Required ──────────────────────────────────────────────────────────────

# NBP (Gemini 3 Pro Image) — required for all image generation (poster
# backgrounds, inline landing/deck imagery).
GEMINI_API_KEY=AIza...

# ── LLM credentials (at least one required) ───────────────────────────────

# OpenRouter (recommended) — one key powers BOTH Anthropic-style
# (Claude) and OpenAI-compat (Kimi / DeepSeek / Qwen / Doubao / etc)
# endpoints. Default planner+critic (moonshotai/kimi-k2.6) uses this.
OPENROUTER_API_KEY=sk-or-v1-...

# Stock Anthropic — only if you want to call Claude directly without
# going through OpenRouter. Not required when OPENROUTER_API_KEY is set.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection (optional — defaults are listed) ──────────────────────

# Default: both planner and critic use moonshotai/kimi-k2.6 via OpenAI-compat.
# Provider is auto-detected from model id prefix: `anthropic/...` or
# `claude-...` → Anthropic backend; everything else → OpenAI-compat backend.
#
# Switch to Claude (both roles):
#   PLANNER_MODEL=anthropic/claude-opus-4.7
#   CRITIC_MODEL=anthropic/claude-opus-4.7
#
# Mix-and-match (Claude planner + DeepSeek critic):
#   PLANNER_MODEL=anthropic/claude-opus-4.7
#   CRITIC_MODEL=deepseek/deepseek-r1
#
# Force a provider when auto-detection guesses wrong:
#   PLANNER_PROVIDER=openai_compat   # auto | anthropic | openai_compat
#   CRITIC_PROVIDER=anthropic

# PLANNER_MODEL=moonshotai/kimi-k2.6
# CRITIC_MODEL=moonshotai/kimi-k2.6
# PLANNER_PROVIDER=auto
# CRITIC_PROVIDER=auto

# ── Extended thinking / reasoning budget ──────────────────────────────────

# Both backends honour these. budget=0 disables thinking entirely (faster
# + cheaper; useful for dev runs). Anthropic uses the thinking={} block;
# OpenAI-compat uses extra_body.reasoning.max_tokens (OpenRouter unified
# format — providers that don't support it ignore it silently).
# PLANNER_THINKING_BUDGET=10000
# CRITIC_THINKING_BUDGET=10000

# Anthropic-only: interleaved-thinking-2025-05-14 beta header — lets
# Claude emit thinking blocks *between* tool calls instead of only at
# turn start. No-op for OpenAI-compat backends.
# ENABLE_INTERLEAVED_THINKING=1

# ── Self-hosted / alternative OpenAI-compat endpoints ─────────────────────

# Override base_url + key to point at self-hosted vLLM / SGLang / native
# Moonshot API / DeepSeek API / ByteDance Doubao / etc. Defaults to
# OpenRouter's /api/v1 when unset.
# OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPAT_API_KEY=dummy

# ── v1.2 paper2any: ingest VLM (PDF structure + caption matching) ─────────

# Used by ingest_document for reading the paper and matching captions to
# pymupdf-extracted figures. Qwen-VL-Max on OpenRouter is cheap + fast +
# strong enough; swap to claude-sonnet-4-7 for A/B testing.
# INGEST_MODEL=qwen/qwen-vl-max
# INGEST_HTTP_TIMEOUT=600
